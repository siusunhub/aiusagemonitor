<Window x:Class="AIUsageMonitor.CodexAccountsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex Accounts" Width="640" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" Topmost="True"
        ResizeMode="NoResize" ShowInTaskbar="True">
    <StackPanel Margin="16">
        <ListBox x:Name="AccountsList" Height="180" Margin="0,0,0,8"
                 SelectionChanged="OnSelectionChanged" FontSize="12"/>

        <TextBlock x:Name="StatusText" Margin="0,0,0,10" MinHeight="16" TextWrapping="Wrap"
                   FontSize="12" Foreground="#B8860B"/>

        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Alias:" VerticalAlignment="Center"/>
            <TextBox x:Name="AliasBox" Width="130" Margin="6,0,10,0" MaxLength="32"
                     PreviewTextInput="OnAliasInput" VerticalContentAlignment="Center"/>
            <Button x:Name="RenameBtn" Content="Rename" Click="OnRename" Padding="8,3" Margin="0,0,6,0"/>
            <Button x:Name="AddBtn" Content="＋ Add (login…)" Click="OnAdd" Padding="8,3" Margin="0,0,6,0"/>
            <Button x:Name="RemoveBtn" Content="－ Remove" Click="OnRemove" Padding="8,3" Margin="0,0,6,0"/>
            <Button Content="Close" IsCancel="True" Padding="12,3"/>
        </StackPanel>
    </StackPanel>
</Window>
