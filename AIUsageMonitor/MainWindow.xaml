<Window x:Class="AIUsageMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Usage Monitor"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight">

    <Border x:Name="RootBorder" CornerRadius="6" Background="#D01F1F1F"
            BorderBrush="#30FFFFFF" BorderThickness="1" Padding="8,2">
        <ItemsControl x:Name="ToolsList">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4,0"
                                ToolTip="{Binding Tooltip}" Visibility="{Binding Visibility}">
                        <TextBlock Text="|" Foreground="#50FFFFFF" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   Visibility="{Binding SeparatorVisibility}"/>
                        <TextBlock Text="{Binding Name}" Foreground="#909090"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>

                        <!-- fallback (no percentage data) -->
                        <TextBlock Text="{Binding FallbackText}" Foreground="LightGray"
                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center"
                                   Visibility="{Binding FallbackVisibility}"/>

                        <!-- 5h / weekly rows -->
                        <StackPanel VerticalAlignment="Center" Visibility="{Binding RowsVisibility}">
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <TextBlock Text="5h" Foreground="#808080" FontSize="9"
                                           Width="15" VerticalAlignment="Center"/>
                                <Grid Height="4" Width="52" VerticalAlignment="Center">
                                    <Border Background="#40FFFFFF" CornerRadius="2"/>
                                    <Border Background="{Binding Row1Brush}" CornerRadius="2"
                                            HorizontalAlignment="Left" Width="{Binding Row1BarWidth}"/>
                                </Grid>
                                <TextBlock Text="{Binding Row1Text}" Foreground="{Binding Row1Brush}"
                                           FontSize="9" FontWeight="Bold"
                                           Margin="3,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <TextBlock Text="wk" Foreground="#808080" FontSize="9"
                                           Width="15" VerticalAlignment="Center"/>
                                <Grid Height="4" Width="52" VerticalAlignment="Center">
                                    <Border Background="#40FFFFFF" CornerRadius="2"/>
                                    <Border Background="{Binding Row2Brush}" CornerRadius="2"
                                            HorizontalAlignment="Left" Width="{Binding Row2BarWidth}"/>
                                </Grid>
                                <TextBlock Text="{Binding Row2Text}" Foreground="{Binding Row2Brush}"
                                           FontSize="9" FontWeight="Bold"
                                           Margin="3,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- compact circular gauges (5h + wk) -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding CircleVisibility}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                                <TextBlock Text="5h" Foreground="#808080" FontSize="9"
                                           VerticalAlignment="Center" Margin="0,0,2,0"/>
                                <Grid Width="24" Height="24">
                                    <Ellipse Width="20" Height="20" Stroke="#40FFFFFF" StrokeThickness="4"/>
                                    <Path Data="{Binding Ring1Geometry}" Stroke="{Binding Ring1Brush}"
                                          StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <TextBlock Text="{Binding Ring1CenterText}" Foreground="{Binding Ring1Brush}"
                                               FontSize="8" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="wk" Foreground="#808080" FontSize="9"
                                           VerticalAlignment="Center" Margin="0,0,2,0"/>
                                <Grid Width="24" Height="24">
                                    <Ellipse Width="20" Height="20" Stroke="#40FFFFFF" StrokeThickness="4"/>
                                    <Path Data="{Binding Ring2Geometry}" Stroke="{Binding Ring2Brush}"
                                          StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <TextBlock Text="{Binding Ring2CenterText}" Foreground="{Binding Ring2Brush}"
                                               FontSize="8" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <!-- 5h reset countdown, centered like the tool name (both modes) -->
                        <TextBlock Text="{Binding Row1ResetText}" Foreground="#909090"
                                   FontSize="11" FontWeight="SemiBold" Margin="4,0,0,0"
                                   VerticalAlignment="Center" Visibility="{Binding ResetVisibility}"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</Window>
